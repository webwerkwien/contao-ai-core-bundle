{
    "name": "webwerkwien/contao-cli-bridge",
    "description": "Contao 5 console commands for agent-driven CRUD operations",
    "type": "contao-bundle",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "contao/core-bundle": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "symfony/console": "^6.0"
    },
    "autoload": {
        "psr-4": {
            "Webwerkwien\\ContaoCliBridgeBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Webwerkwien\\ContaoCliBridgeBundle\\Tests\\": "tests/"
        }
    },
    "extra": {
        "contao-manager-plugin": "Webwerkwien\\ContaoCliBridgeBundle\\ContaoManager\\Plugin"
    }
}
